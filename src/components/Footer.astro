---
/**
 * Footer Component
 * Minimal footer: copyright, social links (GitHub, Twitter/X).
 * Warm, understated design consistent with Anthropic aesthetic.
 */

const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/tangxin',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
    </svg>`,
  },
  {
    label: 'X (Twitter)',
    href: 'https://x.com/tangxin',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>`,
  },
];
---

<footer class="mt-auto border-t border-warm">
  <div class="site-container py-8 sm:py-10">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">

      <!-- Copyright -->
      <p class="text-sm text-warm-muted">
        &copy; {currentYear} Tang Xin. All rights reserved.
      </p>

      <!-- Social Links -->
      <div class="flex items-center gap-1">
        {socialLinks.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.label}
            class="inline-flex items-center justify-center w-9 h-9 rounded-md text-ink-lighter hover:text-ink hover:bg-surface-muted transition-colors duration-150 cursor-pointer"
            set:html={social.icon}
          />
        ))}
      </div>
    </div>
  </div>
</footer>
