---
/**
 * Header Component
 * Anthropic Engineering Blog-style minimal navigation.
 * - Logo/site name on left
 * - Nav links: Home, Daily, Insights, Papers
 * - Mobile: collapsible nav via JS toggle
 */

export interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navLinks = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/daily/`, label: 'Daily' },
  { href: `${base}/insights/`, label: 'Insights' },
  { href: `${base}/papers/`, label: 'Papers' },
];

function isActive(href: string): boolean {
  if (href === `${base}/`) {
    return currentPath === '/' || currentPath === `${base}/`;
  }
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-40 w-full bg-warm/95 backdrop-blur-sm border-b border-warm" id="site-header">
  <div class="site-container">
    <div class="flex items-center justify-between h-14 sm:h-16">

      <!-- Logo / Site Name -->
      <a
        href={`${base}/`}
        class="flex items-center gap-2 group"
        aria-label="Back to home"
      >
        <!-- Wordmark icon: small warm square accent -->
        <span
          class="flex-shrink-0 w-6 h-6 rounded-sm bg-primary-900 flex items-center justify-center"
          aria-hidden="true"
        >
          <span class="w-2.5 h-2.5 rounded-sm bg-primary-200"></span>
        </span>
        <span
          class="font-display text-base font-normal tracking-tight text-ink group-hover:text-primary-800 transition-colors duration-150"
        >
          Tang Xin
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden sm:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-1.5 rounded-md text-sm transition-colors duration-150',
              isActive(link.href)
                ? 'bg-primary-100 text-primary-900 font-medium'
                : 'text-ink-light hover:text-ink hover:bg-surface-muted',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile: Hamburger Button -->
      <button
        class="sm:hidden nav-toggle"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
        id="mobile-nav-toggle"
        type="button"
      >
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Nav Drawer -->
  <div
    id="mobile-nav"
    class="sm:hidden overflow-hidden transition-all duration-200 ease-in-out"
    style="max-height: 0;"
    aria-hidden="true"
  >
    <nav class="site-container pb-4 pt-1 flex flex-col gap-1" aria-label="Mobile navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'px-3 py-2.5 rounded-md text-sm transition-colors duration-150',
            isActive(link.href)
              ? 'bg-primary-100 text-primary-900 font-medium'
              : 'text-ink-light hover:text-ink hover:bg-surface-muted',
          ]}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-nav-toggle');
  const nav = document.getElementById('mobile-nav');
  const header = document.getElementById('site-header');

  if (toggle && nav && header) {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      const nextState = !isOpen;

      toggle.setAttribute('aria-expanded', String(nextState));
      nav.setAttribute('aria-hidden', String(!nextState));
      header.classList.toggle('nav-open', nextState);

      if (nextState) {
        // Expand: set max-height to scrollHeight for smooth animation
        nav.style.maxHeight = nav.scrollHeight + 'px';
      } else {
        nav.style.maxHeight = '0';
      }
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!header.contains(e.target as Node)) {
        toggle.setAttribute('aria-expanded', 'false');
        nav.setAttribute('aria-hidden', 'true');
        nav.style.maxHeight = '0';
        header.classList.remove('nav-open');
      }
    });

    // Close on link click
    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        nav.setAttribute('aria-hidden', 'true');
        nav.style.maxHeight = '0';
        header.classList.remove('nav-open');
      });
    });
  }
</script>
