---
/**
 * DateSlider.astro
 * Horizontal scrollable month-pill navigator for filtering posts by date.
 * Matches Anthropic blog aesthetic: white bg, near-black text, subtle grey borders.
 */

export interface Props {
  months: { label: string; value: string; count: number }[];
  currentMonth?: string;
}

const { months, currentMonth } = Astro.props;
---

<div class="sticky top-0 z-10 border-b border-warm bg-white/90 backdrop-blur-sm">
  <div class="site-container">
    <div id="date-slider" role="tablist" aria-label="Filter posts by month">
      {months.map(({ label, value, count }) => (
        <button
          role="tab"
          aria-selected={value === currentMonth ? 'true' : 'false'}
          data-month={value}
          class:list={['date-pill', value === currentMonth && 'date-pill--active']}
        >
          {label}
          <span class="date-pill__count">{count}</span>
        </button>
      ))}
    </div>
  </div>
</div>

<style>
  #date-slider {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-block: 0.75rem;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #date-slider::-webkit-scrollbar {
    display: none;
  }

  .date-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    flex-shrink: 0;
    white-space: nowrap;
    border-radius: 9999px;
    border: 1px solid #e5e5e5;
    padding: 0.375rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #737373;
    background: transparent;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background-color 0.15s;
  }
  .date-pill:hover:not(.date-pill--active) {
    border-color: #a8a29e;
    color: #141413;
  }
  .date-pill--active {
    background-color: #141413;
    color: #ffffff;
    border-color: #141413;
  }
  .date-pill__count {
    font-size: 0.75rem;
    opacity: 0.55;
  }
</style>

<script>
  const slider = document.getElementById('date-slider');
  if (slider) {
    const pills = slider.querySelectorAll<HTMLButtonElement>('.date-pill');
    const sections = document.querySelectorAll<HTMLElement>('[data-month-section]');

    function activate(month: string) {
      sections.forEach((sec) => {
        sec.hidden = sec.dataset.monthSection !== month;
      });
      pills.forEach((pill) => {
        const active = pill.dataset.month === month;
        pill.setAttribute('aria-selected', active ? 'true' : 'false');
        pill.classList.toggle('date-pill--active', active);
      });
      const activePill = slider.querySelector<HTMLButtonElement>(`[data-month="${month}"]`);
      activePill?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }

    pills.forEach((pill) => {
      pill.addEventListener('click', () => activate(pill.dataset.month!));
    });

    // Activate the initially selected month on load
    const initial = slider.querySelector<HTMLButtonElement>('[aria-selected="true"]');
    if (initial?.dataset.month) {
      activate(initial.dataset.month);
      requestAnimationFrame(() =>
        initial.scrollIntoView({ behavior: 'instant' as ScrollBehavior, block: 'nearest', inline: 'center' })
      );
    }
  }
</script>
