---
/**
 * PostCard.astro
 * Card component for listing posts on index pages.
 * Anthropic Engineering Blog style: clean white, serif title, minimal decoration.
 */

export interface Props {
  /** Post page URL */
  href: string;
  /** Post title */
  title: string;
  /** Publication date */
  date: Date;
  /** Short summary */
  summary?: string;
  /** Cover image path/URL */
  cover?: string;
  /** Cover image alt text */
  coverAlt?: string;
  /** Tags */
  tags?: string[];
  /** Category — shown as small dot label */
  category?: 'skill' | 'claude-code' | 'paper' | 'thought' | 'tech' | 'daily';
  /** 'grid' (default) stacks image on top; 'list' shows image on the side */
  layout?: 'grid' | 'list';
  /** 'featured' renders a larger prominent card */
  featured?: boolean;
  /** Language for date formatting */
  lang?: 'zh' | 'en';
}

const {
  href,
  title,
  date,
  summary,
  cover,
  coverAlt = '',
  tags = [],
  category,
  layout = 'grid',
  featured = false,
  lang = 'zh',
} = Astro.props;

const formattedDate = new Intl.DateTimeFormat(lang === 'zh' ? 'zh-CN' : 'en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).format(date);

const isoDate = date.toISOString().split('T')[0];

const categoryLabels: Record<string, string> = {
  skill:        'Skill',
  'claude-code':'Claude Code',
  paper:        'Paper',
  thought:      'Thought',
  tech:         'Tech',
  daily:        'Daily',
};

const isList = layout === 'list';
---

{featured ? (
  <!-- Featured card: wide layout with large image -->
  <article class="group relative overflow-hidden rounded-xl border border-[#e5e5e5] bg-white transition-shadow duration-200 hover:shadow-md">
    <a
      href={href}
      class="after:absolute after:inset-0 focus-visible:outline-none focus-visible:after:ring-2 focus-visible:after:ring-primary-600 focus-visible:after:ring-offset-2 focus-visible:after:rounded-xl"
      tabindex="0"
    >
      {cover && (
        <div class="overflow-hidden">
          <img
            src={cover}
            alt={coverAlt}
            class="w-full aspect-[21/9] object-cover transition-transform duration-500 ease-out group-hover:scale-[1.02]"
            loading="eager"
            decoding="async"
            width="1200"
            height="514"
          />
        </div>
      )}
    </a>
    <div class="p-7 sm:p-9">
      <div class="mb-3 flex items-center gap-3">
        {category && (
          <span class:list={['category-badge', `category-badge--${category}`]}>
            {categoryLabels[category] ?? category}
          </span>
        )}
        <time datetime={isoDate} class="text-xs text-warm-muted tabular-nums">
          {formattedDate}
        </time>
      </div>
      <h2 class="font-display text-2xl sm:text-3xl leading-snug text-ink group-hover:text-primary-700 transition-colors duration-150">
        <a
          href={href}
          class="after:absolute after:inset-0 focus-visible:outline-none"
          tabindex="-1"
          aria-hidden="true"
        >
          {title}
        </a>
      </h2>
      {summary && (
        <p class="mt-3 text-base text-ink-light leading-relaxed line-clamp-3">
          {summary}
        </p>
      )}
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2" aria-label="Tags">
          {tags.slice(0, 5).map((tag) => (
            <span class="tag-badge">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </article>
) : (
  <!-- Standard card: grid or list layout -->
  <article
    class:list={[
      'group relative bg-white rounded-xl border border-[#e5e5e5] overflow-hidden card-hover',
      'transition-colors duration-200 hover:border-[#d4d4d4]',
      isList ? 'flex flex-row' : 'flex flex-col',
    ]}
  >
    <!-- Cover image -->
    {cover && (
      <div
        class:list={[
          'flex-shrink-0 overflow-hidden bg-[#f5f5f5]',
          isList
            ? 'w-32 sm:w-44 md:w-52 aspect-[4/3]'
            : 'aspect-[16/9] w-full',
        ]}
      >
        <img
          src={cover}
          alt={coverAlt}
          class="w-full h-full object-cover transition-transform duration-300 ease-out group-hover:scale-[1.03]"
          loading="lazy"
          decoding="async"
          width="640"
          height="360"
        />
      </div>
    )}

    <!-- No cover placeholder — subtle neutral block -->
    {!cover && !isList && (
      <div class="aspect-[16/9] w-full bg-[#fafafa] flex items-center justify-center border-b border-[#f0f0f0]">
        <span class="w-8 h-8 rounded-sm bg-[#e5e5e5]" aria-hidden="true"></span>
      </div>
    )}

    <!-- Content area -->
    <div
      class:list={[
        'flex flex-col gap-2',
        isList ? 'flex-1 p-4 sm:p-5' : 'p-5 sm:p-6',
      ]}
    >

      <!-- Category + date row -->
      <div class="flex flex-wrap items-center gap-2">
        {category && (
          <span class:list={['category-badge', `category-badge--${category}`]}>
            {categoryLabels[category] ?? category}
          </span>
        )}
        <time
          datetime={isoDate}
          class="text-xs text-warm-muted tabular-nums ml-auto"
        >
          {formattedDate}
        </time>
      </div>

      <!-- Title — clickable via ::after overlay -->
      <h2
        class:list={[
          'font-display leading-snug text-ink group-hover:text-primary-700 transition-colors duration-150',
          isList ? 'text-base sm:text-lg' : 'text-lg sm:text-xl',
        ]}
      >
        <a
          href={href}
          class="after:absolute after:inset-0 focus-visible:outline-none focus-visible:after:ring-2 focus-visible:after:ring-primary-600 focus-visible:after:ring-offset-2 focus-visible:after:rounded-xl"
        >
          {title}
        </a>
      </h2>

      <!-- Summary -->
      {summary && (
        <p
          class:list={[
            'text-sm text-ink-light leading-relaxed',
            isList ? 'line-clamp-2' : 'line-clamp-3',
          ]}
        >
          {summary}
        </p>
      )}

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-auto pt-1" aria-label="Tags">
          {tags.slice(0, 4).map((tag) => (
            <span class="tag-badge">#{tag}</span>
          ))}
          {tags.length > 4 && (
            <span class="tag-badge">+{tags.length - 4}</span>
          )}
        </div>
      )}

    </div>
  </article>
)}
